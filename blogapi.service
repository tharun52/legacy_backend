[Unit]
Description=Blog API - ASP.NET Core
After=network.target

[Service]
WorkingDirectory=/home/ubuntu/legacy_backend
ExecStart=/usr/bin/dotnet /home/ubuntu/legacy_backend/bin/Release/net10.0/BlogApi.dll
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=blogapi
User=ubuntu
Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=ASPNETCORE_URLS=http://0.0.0.0:5000

[Install]
WantedBy=multi-user.target
